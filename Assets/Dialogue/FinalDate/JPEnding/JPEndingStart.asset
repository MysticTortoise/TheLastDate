  m_Script: {fileID: 11500000, guid: f861ef692791412891731b90b159bee1, type: 3}
  m_Name: JPEndingStart
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSequence
  dialogueNodes:
  - Message:
      Message: Hey there!
      SpeakerTitle: Jack Prawn
    DialogueActionsStart:
    - {fileID: 11400000, guid: b44614705eacd2d4e87eb31e2499d89f, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: Jack. I have a confession to make.
      SpeakerTitle: John Guy
    DialogueActionsStart:
    - {fileID: 11400000, guid: db7f830d2265e6149a903610086c6bdb, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: This whole time I've been trying to impress the wrong person.
      SpeakerTitle: John Guy
    DialogueActionsStart:
    - {fileID: 11400000, guid: db7f830d2265e6149a903610086c6bdb, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: But she could never measure up to you.
      SpeakerTitle: John Guy
    DialogueActionsStart:
    - {fileID: 11400000, guid: db7f830d2265e6149a903610086c6bdb, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: What are you trying to say?
      SpeakerTitle: Jack Prawn
    DialogueActionsStart:
    - {fileID: 11400000, guid: 1a16a5179a1defe45b223f93998387dc, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: Jack Prawn. You are one in a krillion. And I want you to be my forever
        gym buddy.
      SpeakerTitle: John Guy
    DialogueActionsStart:
    - {fileID: 11400000, guid: db7f830d2265e6149a903610086c6bdb, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: Will you date me.
      SpeakerTitle: John Guy
    DialogueActionsStart:
    - {fileID: 11400000, guid: db7f830d2265e6149a903610086c6bdb, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: John Guy....
      SpeakerTitle: Jack Prawn
    DialogueActionsStart:
    - {fileID: 11400000, guid: 1a16a5179a1defe45b223f93998387dc, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: I will!
      SpeakerTitle: Jack Prawn
    DialogueActionsStart:
    - {fileID: 11400000, guid: e75801ed4da2f4c418aa052a0deb2709, type: 2}
    DialogueActionsEnd: []
    Options: []
