  dialogueNodes:
  - Message:
      Message: 'I''m really sorry about how I''ve treated you, Jessica. '
      SpeakerTitle: John Guy
    DialogueActionsStart:
    - {fileID: 11400000, guid: 59eb05573a0c4134c9a723c3f8623f22, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: You didn't deserve that treatment, and I want to do better. Thank
        for giving me a second chance.
      SpeakerTitle: John Guy
    DialogueActionsStart: []
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: I appreciate that. Thank you.
      SpeakerTitle: Jessica
    DialogueActionsStart: []
    DialogueActionsEnd: []
