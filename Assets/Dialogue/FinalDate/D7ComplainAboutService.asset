  dialogueNodes:
  - Message:
      Message: God, the service here sucks! How long has it been since we asked for
        the check?
      SpeakerTitle: John Guy
    DialogueActionsStart: []
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: I don't think it's been very long at all.
      SpeakerTitle: Jessica
    DialogueActionsStart: []
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: No, it must have been!
      SpeakerTitle: John Guy
    DialogueActionsStart: []
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: When that waiter gets here, I'll give them a piece of my mind!
      SpeakerTitle: John Guy
    DialogueActionsStart: []
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: Please don't... I'm sure they're trying their best!
      SpeakerTitle: Jessica
    DialogueActionsStart: []
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: Ugh, fine.
      SpeakerTitle: John Guy
