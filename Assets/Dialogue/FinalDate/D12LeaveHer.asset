%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f861ef692791412891731b90b159bee1, type: 3}
  m_Name: D12LeaveHer
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSequence
  dialogueNodes:
  - Message:
      Message: John Guy... you might be the most romantic man alive.
      SpeakerTitle: Jessica
    DialogueActionsStart:
    - {fileID: 11400000, guid: 0577b439fae384f4081a103de5ff4cf8, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: I know, Jessica. I know.
      SpeakerTitle: Joh Guy
    DialogueActionsStart:
    - {fileID: 11400000, guid: db7f830d2265e6149a903610086c6bdb, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: I'd really like to stay together.
      SpeakerTitle: Jessica
    DialogueActionsStart:
    - {fileID: 11400000, guid: 7b7ca8bb4f57cb940acefe020d3bc544, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: That's everything I've wanted to hear....
      SpeakerTitle: John Guy
    DialogueActionsStart:
    - {fileID: 11400000, guid: db7f830d2265e6149a903610086c6bdb, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: But I can't.
      SpeakerTitle: John Guy
    DialogueActionsStart:
    - {fileID: 11400000, guid: db7f830d2265e6149a903610086c6bdb, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: I've realized that I've outgrown this relationship.
      SpeakerTitle: John Guy
    DialogueActionsStart:
    - {fileID: 11400000, guid: db7f830d2265e6149a903610086c6bdb, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: What does this mean?
      SpeakerTitle: Jessica
    DialogueActionsStart:
    - {fileID: 11400000, guid: 1b03020f035e5d044a49096e92fdeef1, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: I can only date people on my level, Jessica. And unfortunately, you're
        not.
      SpeakerTitle: John Guy
    DialogueActionsStart:
    - {fileID: 11400000, guid: db7f830d2265e6149a903610086c6bdb, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: But... but I love you!
      SpeakerTitle: Jessica
    DialogueActionsStart:
    - {fileID: 11400000, guid: 1b03020f035e5d044a49096e92fdeef1, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: Good luck with that.
      SpeakerTitle: John Guy
    DialogueActionsStart:
    - {fileID: 11400000, guid: db7f830d2265e6149a903610086c6bdb, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: I have someone else in mind... someone who can compete with me in
        my greatness.
      SpeakerTitle: John Guy
    DialogueActionsStart:
    - {fileID: 11400000, guid: db7f830d2265e6149a903610086c6bdb, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: Goodbye Jessica.
      SpeakerTitle: John Guy
    DialogueActionsStart:
    - {fileID: 11400000, guid: db7f830d2265e6149a903610086c6bdb, type: 2}
    DialogueActionsEnd:
    - {fileID: 11400000, guid: b44614705eacd2d4e87eb31e2499d89f, type: 2}
    Options: []
