  m_Name: D6ApologizeGreat
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSequence
  dialogueNodes:
  - Message:
      Message: I am so, so sorry about everything I've done to hurt you, I made you
        feel like you were unimportant to me.
      SpeakerTitle: John Guy
    DialogueActionsStart:
    - {fileID: 11400000, guid: d0b317311b3fc9c4ba0d4e5bf9796464, type: 2}
    - {fileID: 11400000, guid: 0577b439fae384f4081a103de5ff4cf8, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: I'm determined to show you how much you matter tonight.
      SpeakerTitle: John Guy
    DialogueActionsStart: []
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: I will kiss your feet! I'll weep to show I mean it! I'll murder anyone
        who looks at you wrong!
      SpeakerTitle: John Guy
    DialogueActionsStart: []
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: I! CARE! FOR! YOU!
      SpeakerTitle: John Guy
    DialogueActionsStart: []
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: Wow, John Guy... That's so sweet.
      SpeakerTitle: Jessica
    DialogueActionsStart: []
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: Thank you for considering my feelings.
      SpeakerTitle: Jessica
    DialogueActionsStart: []
    DialogueActionsEnd:
