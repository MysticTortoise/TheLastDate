  dialogueNodes:
  - Message:
      Message: Need a ride home?
      SpeakerTitle: John Guy
    DialogueActionsStart:
    - {fileID: 11400000, guid: db7f830d2265e6149a903610086c6bdb, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: Oh, I drove myself. But thank you!
      SpeakerTitle: Jessica
    DialogueActionsStart:
    - {fileID: 11400000, guid: 7b7ca8bb4f57cb940acefe020d3bc544, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: Well, I have an extra special surprise for you. But it's in my car.
      SpeakerTitle: John Guy
    DialogueActionsStart:
    - {fileID: 11400000, guid: db7f830d2265e6149a903610086c6bdb, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: Oh, fun!
      SpeakerTitle: Jessica
    DialogueActionsStart:
    - {fileID: 11400000, guid: 7b7ca8bb4f57cb940acefe020d3bc544, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: Follow me.
      SpeakerTitle: John Guy
    DialogueActionsStart:
    - {fileID: 11400000, guid: db7f830d2265e6149a903610086c6bdb, type: 2}
