  m_Name: D7ReadGreat
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSequence
  dialogueNodes:
  - Message:
      Message: I have demolished three books today. My cranium is ever-expanding.
      SpeakerTitle: John Guy
    DialogueActionsStart:
    - {fileID: 11400000, guid: d0b317311b3fc9c4ba0d4e5bf9796464, type: 2}
    - {fileID: 11400000, guid: 0577b439fae384f4081a103de5ff4cf8, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: Oh, wow! You read quickly!
      SpeakerTitle: Jessica
    DialogueActionsStart: []
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: 'Together, we can consume all the information there is to know in
        this world. '
      SpeakerTitle: John Guy
    DialogueActionsStart: []
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: We can learn all the information there is to know as a team.
      SpeakerTitle: John Guy
    DialogueActionsStart: []
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: No one will be able to match us.
      SpeakerTitle: John Guy
    DialogueActionsStart: []
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: That's... a lot.
      SpeakerTitle: Jessica
    DialogueActionsStart: []
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: I like it.
      SpeakerTitle: Jessica
    DialogueActionsStart: []
    DialogueActionsEnd:
