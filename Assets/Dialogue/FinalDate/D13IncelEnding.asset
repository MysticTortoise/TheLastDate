%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f861ef692791412891731b90b159bee1, type: 3}
  m_Name: D13IncelEnding
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSequence
  dialogueNodes:
  - Message:
      Message: I can't believe it! After everything I've done for her.
      SpeakerTitle: John Guy
    DialogueActionsStart:
    - {fileID: 11400000, guid: db7f830d2265e6149a903610086c6bdb, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: Do not fret, John Guy. You've done well.
      SpeakerTitle: ???
    DialogueActionsStart:
    - {fileID: 11400000, guid: bc3d41fcd61c6e249a3bc95899fc7074, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: Who are you?
      SpeakerTitle: John Guy
    DialogueActionsStart:
    - {fileID: 11400000, guid: db7f830d2265e6149a903610086c6bdb, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: A friend. An ally. A peer.
      SpeakerTitle: ???
    DialogueActionsStart:
    - {fileID: 11400000, guid: 20feb881f5bce8f4c8ed29147d63987e, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: You, kind stranger, are one of us.
      SpeakerTitle: ???
    DialogueActionsStart: []
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: Who is this "us"?
      SpeakerTitle: John Guy
    DialogueActionsStart:
    - {fileID: 11400000, guid: db7f830d2265e6149a903610086c6bdb, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: What do you know about the involuntarily celibate community?
      SpeakerTitle: ???
    DialogueActionsStart:
    - {fileID: 11400000, guid: 20feb881f5bce8f4c8ed29147d63987e, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: You mean... incels?
      SpeakerTitle: John Guy
    DialogueActionsStart:
    - {fileID: 11400000, guid: db7f830d2265e6149a903610086c6bdb, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: Quite right, my good sir. We've been watching you.
      SpeakerTitle: Incel
    DialogueActionsStart:
    - {fileID: 11400000, guid: 20feb881f5bce8f4c8ed29147d63987e, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: What?
      SpeakerTitle: John Guy
    DialogueActionsStart:
    - {fileID: 11400000, guid: db7f830d2265e6149a903610086c6bdb, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: Watching you sit around, letting your body and your soul rot....
      SpeakerTitle: Incel
    DialogueActionsStart:
    - {fileID: 11400000, guid: bc3d41fcd61c6e249a3bc95899fc7074, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: Yes, yes... you have great potential.
      SpeakerTitle: Incel
    DialogueActionsStart:
    - {fileID: 11400000, guid: 20feb881f5bce8f4c8ed29147d63987e, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: You *like* that I do nothing?
      SpeakerTitle: John Guy
    DialogueActionsStart:
    - {fileID: 11400000, guid: db7f830d2265e6149a903610086c6bdb, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: Your inaction is fertile ground to the hatred of the world around
        you. Learn more, if you dare...
      SpeakerTitle: Incel
    DialogueActionsStart:
    - {fileID: 11400000, guid: 20feb881f5bce8f4c8ed29147d63987e, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: (He hands you a hard drive)
      SpeakerTitle: 
    DialogueActionsStart:
    - {fileID: 11400000, guid: bc3d41fcd61c6e249a3bc95899fc7074, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: What's this?
      SpeakerTitle: John Guy
    DialogueActionsStart:
    - {fileID: 11400000, guid: db7f830d2265e6149a903610086c6bdb, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: 'It holds everything you need to begin your journey. '
      SpeakerTitle: Incel
    DialogueActionsStart:
    - {fileID: 11400000, guid: 20feb881f5bce8f4c8ed29147d63987e, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: A link to DoorDash Mountain Dew, lewd anime girl art, and most importantly....
      SpeakerTitle: Incel
    DialogueActionsStart: []
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: Reddit.
      SpeakerTitle: Redditor
    DialogueActionsStart:
    - {fileID: 11400000, guid: bc3d41fcd61c6e249a3bc95899fc7074, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: Careful not to lose it, the power it contains is strong. Join us....
      SpeakerTitle: Redditor
    DialogueActionsStart:
    - {fileID: 11400000, guid: 20feb881f5bce8f4c8ed29147d63987e, type: 2}
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: (He throws his arms back and runs off into the night.)
      SpeakerTitle: 
    DialogueActionsStart: []
    DialogueActionsEnd: []
    Options: []
  - Message:
      Message: ...
      SpeakerTitle: John Guy
    DialogueActionsStart:
    - {fileID: 11400000, guid: bc3d41fcd61c6e249a3bc95899fc7074, type: 2}
    DialogueActionsEnd:
    - {fileID: 11400000, guid: 9a8f51fa8226d4845a6582e0dddc9435, type: 2}
    Options: []
